# Copy this file to .env and fill in real values. Never commit .env.

# Postgres (matches docker-compose.yml defaults for local dev)
POSTGRES_URL=postgresql+asyncpg://dis_user:dis_password@localhost:5432/digital_identity

# Qdrant (matches docker-compose.yml defaults for local dev)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=document_chunks

# Neo4j (matches docker-compose.yml defaults for local dev)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=dis_password

# Local Auth
JWT_SECRET=

# LLM providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# App
ENVIRONMENT=development
CORS_ORIGINS=["http://localhost:3000"]
